# --- Google OAuth 2.0 (Google Cloud Console > Credentials > OAuth client ID) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# En prod : https://votre-domaine.com/auth/callback
# En local : http://localhost:3000/auth/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# Restriction SSO : seuls les comptes Google de ce domaine peuvent se connecter.
# Laisser vide pour autoriser tous les comptes (déconseillé en prod).
ALLOWED_GOOGLE_DOMAIN=bleucitron.net

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=sk-ant-

# --- Session ---
# Générer avec : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ⚠ Sert aussi à chiffrer les tokens stockés (data/) : le changer déconnecte tout le monde.
SESSION_SECRET=

# --- Analyse ---
# Nombre max de fils couverts par analyse (45 derniers jours). Vide = 250.
ANALYSIS_MAX_THREADS=250

# --- Digest matinal ---
# Heure d'envoi du récapitulatif quotidien par e-mail (heure de Paris). Vide = 8.
DIGEST_HOUR=8

# --- Serveur ---
PORT=3000
# 'production' active les cookies sécurisés (HTTPS requis derrière le tunnel)
NODE_ENV=development
# URL publique de l'app (pour les liens dans le digest). Déduite du redirect URI si vide.
APP_URL=
