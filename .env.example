# --- Google OAuth 2.0 (Google Cloud Console > Credentials > OAuth client ID) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# En prod : https://votre-domaine.com/auth/callback
# En local : http://localhost:3000/auth/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=sk-ant-

# --- Session ---
# Générer avec : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# --- Serveur ---
PORT=3000
# 'production' active les cookies sécurisés (HTTPS requis derrière le tunnel)
NODE_ENV=development
